\@writefile{lof}{\contentsline {figure}{\numberline {2}{\ignorespaces Naturally occurring noise types in VSR, illustrated via synthetic face renderings with each degradation applied. From left to right: \textbf  {Clean} (reference); \textbf  {Motion Blur} (Gaussian blur emulating camera shake or fast movement); \textbf  {Glare/Specular} (bright highlight patches from glasses or sunlight); \textbf  {Low Light} (severe darkening with added noise, common in indoor or evening capture); \textbf  {Facial Hair/Occlusion} (moustache and beard coverage occluding the lip and perioral region); \textbf  {Off-Angle Pose} (affine horizontal shear approximating mild-to-moderate yaw). Our perturbation evaluation sweeps four of these families\nobreakspace  {}\cite  {hong2023watchorlisten} at mild, moderate, and severe severity levels.\relax }}{5}{figure.caption.2}\protected@file@percent }
\@writefile{brf}{\backcite{hong2023watchorlisten}{{5}{2}{figure.caption.2}}}
\newlabel{fig:noise_types}{{2}{5}{Naturally occurring noise types in VSR, illustrated via synthetic face renderings with each degradation applied. From left to right: \textbf {Clean} (reference); \textbf {Motion Blur} (Gaussian blur emulating camera shake or fast movement); \textbf {Glare/Specular} (bright highlight patches from glasses or sunlight); \textbf {Low Light} (severe darkening with added noise, common in indoor or evening capture); \textbf {Facial Hair/Occlusion} (moustache and beard coverage occluding the lip and perioral region); \textbf {Off-Angle Pose} (affine horizontal shear approximating mild-to-moderate yaw). Our perturbation evaluation sweeps four of these families~\cite {hong2023watchorlisten} at mild, moderate, and severe severity levels.\relax }{figure.caption.2}{}}
\newlabel{fig:noise_types@cref}{{[figure][2][]2}{[1][4][]5}}
\@writefile{brf}{\backcite{tong2022videomae}{{5}{2.4}{equation.2.3}}}
