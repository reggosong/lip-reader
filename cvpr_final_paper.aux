\@writefile{lof}{\contentsline {figure}{\numberline {4}{\ignorespaces Noise-aware phoneme-to-text fine-tuning pipeline. Training text (\texttt  {wikitext-2-raw-v1}) is converted to ARPAbet phoneme sequences via CMUdict. The \texttt  {PhonemeNoiseAugmenter} (substitution $p{=}0.15$, insertion $p{=}0.05$, deletion $p{=}0.05$) applies viseme-aware confusions to simulate CTC decoding errors. Each sentence produces three training examples: clean phonemes, noisy phonemes, and a top-$k$ ($k{=}5$) beam hypothesis list with log-prob scores. LLaMA-3.2 is fine-tuned via LoRA\nobreakspace  {}\cite  {hu2022lora} ($r{=}16$, $\alpha {=}32$, dropout $0.05$) to map all three input types back to clean text.\relax }}{7}{figure.caption.4}\protected@file@percent }
\@writefile{brf}{\backcite{hu2022lora}{{7}{4}{figure.caption.4}}}
\newlabel{fig:finetune}{{4}{7}{Noise-aware phoneme-to-text fine-tuning pipeline. Training text (\texttt {wikitext-2-raw-v1}) is converted to ARPAbet phoneme sequences via CMUdict. The \texttt {PhonemeNoiseAugmenter} (substitution $p{=}0.15$, insertion $p{=}0.05$, deletion $p{=}0.05$) applies viseme-aware confusions to simulate CTC decoding errors. Each sentence produces three training examples: clean phonemes, noisy phonemes, and a top-$k$ ($k{=}5$) beam hypothesis list with log-prob scores. LLaMA-3.2 is fine-tuned via LoRA~\cite {hu2022lora} ($r{=}16$, $\alpha {=}32$, dropout $0.05$) to map all three input types back to clean text.\relax }{figure.caption.4}{}}
\newlabel{fig:finetune@cref}{{[figure][4][]4}{[1][6][]7}}
\@writefile{brf}{\backcite{thomas2025vallr}{{7}{2.9}{table.caption.5}}}
